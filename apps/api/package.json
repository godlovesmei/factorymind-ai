{
  "name": "@factorymind/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint src --config ../../eslint.config.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@factorymind/shared": "workspace:*",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "socket.io": "^4.8.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/node": "^25.9.3",
    "@types/supertest": "^6.0.3",
    "eslint": "^10.5.0",
    "supertest": "^7.1.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "vitest": "^3.1.0"
  }
}
