# General
NODE_ENV=development
DEMO_MODE=true

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000

# Backend
API_PORT=4000
JWT_SECRET=change-this-secret
CORS_ORIGIN=http://localhost:3000

# Database
DATABASE_URL=mysql://factorymind:factorymind@localhost:3306/factorymind
SHADOW_DATABASE_URL=mysql://factorymind:factorymind@localhost:3306/factorymind_shadow
MYSQL_DATABASE=factorymind
MYSQL_USER=factorymind
MYSQL_PASSWORD=factorymind
MYSQL_ROOT_PASSWORD=factorymind-root

# MQTT
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=

# AI
AI_PROVIDER=mock
GEMINI_API_KEY=
OPENAI_API_KEY=

# ML Service
ML_SERVICE_URL=http://localhost:8000

# Legacy Laravel
LEGACY_API_URL=http://localhost:5000/api
LEGACY_API_TOKEN=change-this-token
