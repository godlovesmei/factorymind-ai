{
  "name": "factorymind-ai",
  "version": "0.1.0",
  "private": true,
  "description": "Smart manufacturing operations dashboard with realtime IoT simulation, Node.js APIs, MySQL, and future AI-assisted reporting.",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=24.14.0",
    "pnpm": ">=11.7.0"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter @factorymind/web --filter @factorymind/api dev",
    "dev:web": "pnpm --filter @factorymind/web dev",
    "dev:api": "pnpm --filter @factorymind/api dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "db:up": "docker compose up -d mysql",
    "db:down": "docker compose down",
    "db:generate": "dotenv -e .env -- pnpm --filter @factorymind/database db:generate",
    "db:migrate": "dotenv -e .env -- pnpm --filter @factorymind/database db:migrate",
    "db:seed": "dotenv -e .env -- pnpm --filter @factorymind/database db:seed",
    "db:studio": "dotenv -e .env -- pnpm --filter @factorymind/database db:studio"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.5.0",
    "prettier": "^3.8.4",
    "typescript-eslint": "^8.61.0",
    "typescript": "^6.0.3"
  }
}
